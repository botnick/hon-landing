---
export const prerender = false;
import Admin from '../../layouts/Admin.astro';
import { CAN, type AuthedUser } from '../../lib/session';
import { readLive, readVersion, currentLiveVersion } from '../../lib/content-store';
import { deriveJsonLdString } from '../../lib/seo-derive';
import type { D1Database } from '../../lib/db';

const user = (Astro.locals as any).user as AuthedUser;
const canEdit = CAN.editContent(user);
const env = (Astro.locals as any).runtime?.env as { CMS_DB?: D1Database; CMS_KV?: any } | undefined;
const db = (Astro.locals as any).db as D1Database | undefined;
let snap: any = null;
if (db) {
  const live = await currentLiveVersion(db);
  snap = await readLive(env?.CMS_KV);
  if (!snap && live) snap = await readVersion(db, live);
}
// Server-derived preview so the user sees exactly what JSON-LD will ship — read-only.
const derivedTh = snap ? deriveJsonLdString(snap, 'th') : '';
---
<Admin title="การค้นหา (SEO)" active="seo">
  <div class="page-h">
    <div>
      <h1>การค้นหา (SEO)</h1>
      <div class="sub">ข้อความที่ขึ้นตอนคนค้นเจอเว็บ หรือแชร์ลิงก์ — กรอกแค่หัวข้อกับคำอธิบาย ที่เหลือระบบทำให้</div>
    </div>
    <button class="btn primary sm" id="publishBtn" disabled={!canEdit}>เผยแพร่ขึ้นเว็บ</button>
  </div>

  <div class="notice ok" id="okNote" style="display:none"></div>
  <div class="notice err" id="errNote" style="display:none"></div>

  <div id="seoRoot" class="empty">กำลังโหลด…</div>

  <script define:vars={{ snap, derivedTh }}>
    let snapshot = snap;
    let lang = 'th';
    const esc = (s) => String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

    const LANG_TH = { th: 'ภาษาไทย', en: 'ภาษาอังกฤษ' };
    function render() {
      const root = document.getElementById('seoRoot');
      if (!snapshot) { root.textContent = 'ยังไม่มีเนื้อหา'; return; }
      const s = snapshot.seo;
      const tLen = (s.title?.[lang] || '').length, dLen = (s.description?.[lang] || '').length;
      root.innerHTML = `
        <div class="panel">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
            <h2 style="margin:0">ข้อความตอนค้นเจอ / แชร์ลิงก์</h2>
            <span class="lang-tabs" id="seoLang">
              <button data-lang="th" class="${lang === 'th' ? 'active' : ''}">ไทย</button>
              <button data-lang="en" class="${lang === 'en' ? 'active' : ''}">อังกฤษ</button>
            </span>
          </div>
          <div class="field"><label>หัวข้อหน้า · ${LANG_TH[lang]}</label>
            <input id="s-title" value="${esc(s.title?.[lang])}"><div class="hint">${tLen} ตัวอักษร · ไม่ควรเกิน 60 (ยาวไปจะโดนตัดตอนแสดงผล)</div></div>
          <div class="field"><label>คำอธิบายหน้า · ${LANG_TH[lang]}</label>
            <textarea id="s-desc">${esc(s.description?.[lang])}</textarea><div class="hint">${dLen} ตัวอักษร · ไม่ควรเกิน 160</div></div>
        </div>
        <div class="panel"><h2>รูปตอนแชร์ลิงก์ & การมองเห็น</h2>
          <div class="field"><label>รูปที่ขึ้นตอนแชร์ลิงก์</label><input id="s-og" class="mono" value="${esc(s.ogImage)}"><div class="hint">พาธไฟล์รูป เช่น /og.jpg — รูปนี้จะโชว์ตอนแชร์ลิงก์ใน LINE/Facebook</div></div>
          <div class="grid c2">
            <div class="field"><label>ขนาดรูปตอนแชร์</label>
              <select id="s-tw">
                <option value="summary_large_image" ${s.twitterCard === 'summary_large_image' ? 'selected' : ''}>รูปใหญ่เต็มการ์ด</option>
                <option value="summary" ${s.twitterCard === 'summary' ? 'selected' : ''}>รูปเล็กข้างข้อความ</option>
              </select></div>
            <div class="field"><label>ให้ Google เจอหน้านี้ไหม</label>
              <select id="s-robots">
                <option value="index,follow" ${s.robots === 'index,follow' ? 'selected' : ''}>ให้เจอ — แสดงในผลค้นหา</option>
                <option value="noindex,nofollow" ${s.robots === 'noindex,nofollow' ? 'selected' : ''}>ซ่อน — ไม่ให้ขึ้นผลค้นหา</option>
              </select></div>
          </div>
        </div>
        <div class="panel">
          <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:10px">
            <h2 style="margin:0">ข้อมูลสำหรับ Google (สร้างอัตโนมัติ)</h2>
            <span class="pill live">ระบบทำให้</span>
          </div>
          <p style="margin:0 0 10px;color:var(--txt-dim);font-size:12px">ส่วนนี้ระบบสร้างจากเนื้อหาของคุณให้เอง ไม่ต้องแก้ — นี่คือสิ่งที่ Google อ่าน:</p>
          <pre class="mono" style="background:var(--input);border:1px solid var(--line);border-radius:var(--r);padding:12px;font-size:11.5px;color:var(--txt-dim);overflow:auto;max-height:220px;margin:0">${esc(derivedTh)}</pre>
        </div>`;
      wire();
    }
    function wire() {
      const bind = (id, ev, fn) => document.getElementById(id)?.addEventListener(ev, fn);
      bind('s-title', 'input', (e) => { snapshot.seo.title[lang] = e.target.value; });
      bind('s-desc', 'input', (e) => { snapshot.seo.description[lang] = e.target.value; });
      bind('s-og', 'input', (e) => { snapshot.seo.ogImage = e.target.value; });
      bind('s-tw', 'change', (e) => { snapshot.seo.twitterCard = e.target.value; });
      bind('s-robots', 'change', (e) => { snapshot.seo.robots = e.target.value; });
      document.querySelectorAll('#seoLang button').forEach((b) => b.addEventListener('click', () => { lang = b.dataset.lang; render(); }));
    }
    document.getElementById('publishBtn')?.addEventListener('click', async () => {
      const btn = document.getElementById('publishBtn'); btn.disabled = true; btn.textContent = 'กำลังเผยแพร่…';
      // JSON-LD is derived at render time — clear any stored value so the landing derives fresh.
      snapshot.seo.jsonLd = '';
      const res = await fetch('/api/publish', { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({ snapshot, note: 'SEO update via admin' }) });
      const data = await res.json();
      const ok = document.getElementById('okNote'), err = document.getElementById('errNote');
      ok.style.display = 'none'; err.style.display = 'none';
      if (res.ok) { ok.textContent = `เผยแพร่ขึ้นเว็บแล้ว (เวอร์ชัน ${data.version}) — ขึ้นเว็บจริงเรียบร้อย`; ok.style.display = 'block'; }
      else { err.textContent = 'เผยแพร่ไม่สำเร็จ: ' + (data.details ? data.details.join('; ') : data.error); err.style.display = 'block'; }
      btn.disabled = false; btn.textContent = 'เผยแพร่ขึ้นเว็บ';
    });
    render();
  </script>
</Admin>
