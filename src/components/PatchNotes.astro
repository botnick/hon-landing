---
import { getPatchNotes, fallbackContent } from '../lib/content';
const { content = fallbackContent } = Astro.props;
const p = getPatchNotes(content);
const entries = p.entries ?? [];
// Built now, shipped disabled (sections.patchNotes.enabled=false). Enable at launch
// when real entries exist — a faked changelog reads as AI and costs trust. Until then
// this stays a ready scaffold using the same brass-ledger vocabulary as the site.
---
<section class="notes" id="patch-notes">
  <div class="wrap notes-inner">
    <header class="notes-head">
      <p class="act-eyebrow">{p.eyebrow}</p>
      <h2 class="notes-title">{p.title}</h2>
      {p.intro && <p class="notes-intro">{p.intro}</p>}
    </header>

    {entries.length > 0 && (
      <ol class="log" data-stagger role="list">
        {entries.map((e: any) => (
          <li class="entry r-item">
            <div class="entry-meta">
              {e.tag && <span class="entry-tag">{e.tag}</span>}
              {e.date && <time class="entry-date">{e.date}</time>}
            </div>
            <div class="entry-body">
              {e.title && <h3 class="entry-title">{e.title}</h3>}
              {e.body && <p class="entry-text">{e.body}</p>}
            </div>
          </li>
        ))}
      </ol>
    )}
  </div>
</section>

<style>
  .notes { padding-block: var(--section-pad); position: relative; }
  .notes-inner { max-width: 820px; margin-inline: auto; }
  .notes-head { max-width: 60ch; margin-bottom: clamp(2.6rem, 6vh, 4rem); }
  .notes-title { font-size: var(--fs-h2); line-height: var(--lh-head); color: var(--text); letter-spacing: 0.01em; }
  .notes-intro { margin-top: 1rem; color: var(--text-dim); font-size: var(--fs-lead); line-height: var(--lh-body); }

  .log { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--brass-soft); }
  .entry {
    display: grid;
    grid-template-columns: 12rem 1fr;
    gap: clamp(1rem, 3vw, 2.4rem);
    padding-block: clamp(1.8rem, 4vw, 2.6rem);
    border-bottom: 1px solid var(--brass-soft);
  }
  .entry-meta { display: flex; flex-direction: column; gap: 0.5rem; align-items: start; }
  .entry-tag {
    font-family: var(--font-latin); font-weight: 600;
    font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--gold-bright);
    padding: 0.3rem 0.65rem; border: 1px solid var(--brass);
    background: rgba(191,151,73,0.05);
  }
  .entry-date { font-family: var(--font-latin); font-size: 0.82rem; color: var(--text-dim); letter-spacing: 0.03em; }
  .entry-title { font-size: var(--fs-h3); line-height: var(--lh-head); color: var(--text); }
  .entry-text { margin-top: 0.6rem; color: var(--text-dim); font-size: var(--fs-body); line-height: var(--lh-body); max-width: 60ch; }

  @media (max-width: 680px) {
    .entry { grid-template-columns: 1fr; gap: 0.8rem; }
    .entry-meta { flex-direction: row; align-items: center; gap: 0.8rem; }
  }
</style>
