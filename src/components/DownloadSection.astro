---
import { getDownload, getPhaseContent, getUi, fallbackContent } from '../lib/content';

const { content = fallbackContent } = Astro.props;
const d = getDownload(content);
const phase = getPhaseContent(content);
const ui = getUi(content);

// The armory unlocks preloadHours BEFORE the hero countdown hits zero (preload
// window: grab the client early, play the second the gate opens). Both states
// are rendered; the server picks one and the inline script re-checks + ticks a
// countdown in the browser, so a build shipped in the locked state still flips
// on time without a rebuild.
const opensAt = phase.countdownTo;
const preloadMs = (d.client.preloadHours ?? 0) * 3_600_000;
const downloadAtMs = opensAt ? new Date(opensAt).getTime() - preloadMs : 0;
const available = Boolean(d.client.href) && (!opensAt || Date.now() >= downloadAtMs);
---
<div class="dl">
  <!-- Page head band — stone wall + gold haze, same family as the footer -->
  <section class="dl-head" id="download">
    <div class="dl-head-bg" aria-hidden="true">
      <picture>
        <source srcset="/art/stone-wall.avif" type="image/avif" />
        <source srcset="/art/stone-wall.webp" type="image/webp" />
        <img src="/art/stone-wall.webp" alt="" decoding="async" loading="lazy" />
      </picture>
      <div class="dl-head-fade"></div>
    </div>
    <div class="wrap dl-head-inner">
      <p class="act-eyebrow">{d.eyebrow}</p>
      <h1 class="dl-title">{d.title}</h1>
      <p class="dl-subtitle">{d.subtitle}</p>
    </div>
  </section>

  <!-- The client plate: platform / version / size + the one big action -->
  <section class="dl-client">
    <div class="wrap dl-client-inner">
      <article class="client-card">
        <header class="client-head">
          <h2 class="client-name">{d.client.name}</h2>
          <ul class="client-meta">
            <li>{d.client.platform}</li>
            <li>{d.client.version}</li>
            <li>{d.client.size}</li>
          </ul>
        </header>

        <div class="client-action" id="dl-ready" hidden={!available}>
          <a
            class="btn-dl"
            href={d.client.href}
            {...d.client.href.startsWith('http') ? { target: '_blank', rel: 'noopener' } : { download: true }}
          >
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3v12m0 0l-5-5m5 5l5-5" /><path d="M4 19h16" />
            </svg>
            <span>{d.client.buttonLabel}</span>
          </a>
          {d.client.mirrors.length > 0 && (
            <p class="client-mirrors">
              <span>{d.client.mirrorLabel}:</span>
              {d.client.mirrors.map((m: { label: string; href: string }) => (
                <a href={m.href} target="_blank" rel="noopener">{m.label}</a>
              ))}
            </p>
          )}
        </div>
        <div class="client-action" id="dl-locked" hidden={available}>
          <p class="client-locked">
            <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
              <rect x="5" y="11" width="14" height="9" rx="1" /><path d="M8 11V7a4 4 0 0 1 8 0v4" />
            </svg>
            {d.client.lockedNote}
          </p>
          <p class="dl-wait">
            <span class="dl-wait-label">{d.client.lockedCountdownLabel}</span>
            <span class="dl-wait-time" id="dl-cd">--:--:--</span>
          </p>
        </div>
        <script is:inline data-astro-rerun define:vars={{ downloadAtMs, hasHref: Boolean(d.client.href), dayLabel: ui.countdown.day }}>
          // Ticks down to the preload window, then swaps in the live button — so a
          // build shipped in the locked state unseals itself right on time.
          (function () {
            var ready = document.getElementById('dl-ready');
            var locked = document.getElementById('dl-locked');
            var cd = document.getElementById('dl-cd');
            function pad(n) { return String(n).padStart(2, '0'); }
            function fmt(ms) {
              var s = Math.max(0, Math.floor(ms / 1000));
              var days = Math.floor(s / 86400);
              var h = Math.floor((s % 86400) / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
              return (days > 0 ? days + ' ' + dayLabel + ' ' : '') + pad(h) + ':' + pad(m) + ':' + pad(sec);
            }
            var timer = null;
            function tick() {
              var open = hasHref && (!downloadAtMs || Date.now() >= downloadAtMs);
              if (ready && locked) { ready.hidden = !open; locked.hidden = open; }
              if (open) { if (timer) clearInterval(timer); return; }
              if (cd) cd.textContent = fmt(downloadAtMs - Date.now());
            }
            timer = setInterval(tick, 1000);
            tick();
          })();
        </script>
      </article>
    </div>
  </section>

  <!-- Install steps — numbered ledger, same grammar as the Server Oath rows -->
  <section class="dl-steps">
    <div class="wrap dl-steps-inner">
      <h2 class="dl-h2">{d.steps.title}</h2>
      <ol class="steps" data-stagger>
        {d.steps.items.map((s, i) => (
          <li class="step r-item">
            <span class="step-no" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div>
              <h3 class="step-title">{s.title}</h3>
              <p class="step-body">{s.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- Spec table — engraved two-column plate -->
  <section class="dl-specs">
    <div class="wrap dl-specs-inner">
      <h2 class="dl-h2">{d.specs.title}</h2>
      <div class="specs-table" role="table">
        <div class="specs-row specs-row--head" role="row">
          <span role="columnheader"></span>
          <span role="columnheader">{d.specs.minLabel}</span>
          <span role="columnheader">{d.specs.recLabel}</span>
        </div>
        {d.specs.rows.map((r) => (
          <div class="specs-row" role="row">
            <span class="specs-part" role="rowheader">{r.part}</span>
            <span role="cell">{r.min}</span>
            <span class="specs-rec" role="cell">{r.rec}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</div>

<style>
  .dl { padding-top: 0; }

  /* --- Head band --- */
  .dl-head {
    position: relative; isolation: isolate; overflow: hidden;
    padding-block: clamp(7rem, 20vh, 11rem) clamp(3rem, 8vh, 5rem);
  }
  .dl-head-bg { position: absolute; inset: 0; z-index: -1; }
  .dl-head-bg img {
    width: 100%; height: 100%; object-fit: cover; object-position: 50% 30%;
    opacity: 0.4; filter: saturate(0.9) brightness(0.75);
  }
  .dl-head-fade {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(5,7,10,0.7) 0%, transparent 40%, var(--ink) 96%),
      radial-gradient(55% 45% at 50% 20%, rgba(255,198,0,0.07), transparent 70%);
  }
  .dl-head-inner { max-width: 1000px; margin-inline: auto; }
  .dl-title { font-size: var(--fs-h2); line-height: var(--lh-head); color: var(--text); }
  .dl-subtitle { margin-top: 0.9rem; color: var(--text-dim); font-size: var(--fs-lead); line-height: var(--lh-body); max-width: 46ch; }

  .dl-h2 { font-size: var(--fs-h3); line-height: var(--lh-head); color: var(--text); margin-bottom: clamp(1.6rem, 4vh, 2.4rem); }

  /* --- Client plate --- */
  .dl-client-inner, .dl-steps-inner, .dl-specs-inner { max-width: 1000px; margin-inline: auto; }
  .dl-client { padding-block: 0 clamp(2.5rem, 6vh, 4rem); }
  .client-card {
    background: var(--plate);
    border: 1px solid var(--brass);
    box-shadow: var(--hairline-inset), 0 18px 50px -20px rgba(0,0,0,0.8);
    padding: clamp(1.6rem, 4vw, 2.6rem);
    clip-path: polygon(14px 0, calc(100% - 14px) 0, 100% 14px, 100% calc(100% - 14px), calc(100% - 14px) 100%, 14px 100%, 0 calc(100% - 14px), 0 14px);
  }
  .client-head {
    display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.8rem 1.4rem;
    padding-bottom: 1.3rem; margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--brass-soft);
  }
  .client-name {
    font-family: var(--font-latin); font-weight: 700;
    font-size: clamp(1.2rem, 3vw, 1.5rem); letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--gold-bright);
  }
  .client-meta { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem 0; padding: 0; margin: 0; }
  .client-meta li {
    color: var(--text-dim); font-size: var(--fs-small);
    padding-inline: 0.9rem; border-left: 1px solid var(--brass-soft);
  }
  .client-meta li:first-child { border-left: 0; padding-left: 0; }

  .client-action { display: flex; flex-direction: column; align-items: flex-start; gap: 1.1rem; }
  .client-action[hidden] { display: none; } /* hidden must beat display:flex */
  .btn-dl {
    display: inline-flex; align-items: center; gap: 0.65rem;
    font-family: var(--font-display); font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    font-size: 0.95rem; color: #1a1206;
    padding: 0.95rem 2.1rem;
    background: linear-gradient(180deg, var(--gold-bright), var(--gold) 55%, var(--gold-deep));
    border: 1px solid rgba(255,224,138,0.8);
    clip-path: polygon(12px 0, calc(100% - 12px) 0, 100% 50%, calc(100% - 12px) 100%, 12px 100%, 0 50%);
    transition: transform var(--dur-fast) var(--ease-out), filter var(--dur-fast), box-shadow var(--dur-fast);
  }
  .btn-dl:hover { transform: translateY(-2px); filter: brightness(1.08); box-shadow: 0 0 38px rgba(255,198,0,0.55); }
  .btn-dl:active { transform: scale(0.97); }
  .btn-dl svg { width: 20px; height: 20px; }

  .client-locked {
    display: flex; align-items: flex-start; gap: 0.7rem;
    color: var(--text-dim); font-size: var(--fs-body); line-height: var(--lh-body);
    max-width: 58ch;
  }
  .client-locked svg { width: 20px; height: 20px; flex: 0 0 auto; margin-top: 0.2rem; color: var(--gold-deep); }

  /* Preload countdown chip — same engraved-plate grammar as the hero clock */
  .dl-wait {
    display: inline-flex; align-items: baseline; gap: 0.9rem;
    padding: 0.85rem 1.4rem;
    background: linear-gradient(180deg, rgba(0,17,23,0.85), rgba(0,0,0,0.6));
    border: var(--edge-gold);
    box-shadow: inset 0 0 18px rgba(0,0,0,0.6);
    clip-path: polygon(8px 0, calc(100% - 8px) 0, 100% 8px, 100% calc(100% - 8px), calc(100% - 8px) 100%, 8px 100%, 0 calc(100% - 8px), 0 8px);
  }
  .dl-wait-label {
    font-family: var(--font-display); font-weight: 600;
    font-size: var(--fs-small); letter-spacing: 0.06em;
    color: var(--text-dim);
  }
  .dl-wait-time {
    font-family: var(--font-latin); font-weight: 700;
    font-size: clamp(1.2rem, 3vw, 1.6rem); line-height: 1;
    color: var(--gold-bright);
    font-variant-numeric: tabular-nums;
    text-shadow: var(--glow-gold);
  }

  .client-mirrors { display: flex; flex-wrap: wrap; gap: 0.4rem 1rem; font-size: var(--fs-small); color: var(--text-dim); }
  .client-mirrors a { color: var(--gold-bright); text-decoration: underline; text-underline-offset: 3px; }
  .client-mirrors a:hover { color: var(--gold); }

  /* --- Steps ledger --- */
  .dl-steps { padding-block: clamp(2rem, 5vh, 3.5rem); }
  .steps { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--brass-soft); }
  .step {
    display: grid; grid-template-columns: auto 1fr; gap: clamp(1.2rem, 3vw, 2.2rem);
    align-items: start;
    padding-block: clamp(1.5rem, 3.5vw, 2.1rem);
    border-bottom: 1px solid var(--brass-soft);
  }
  .step-no {
    font-family: var(--font-latin); font-weight: 700;
    font-size: clamp(1.4rem, 3.4vw, 1.9rem); line-height: 1.3;
    color: var(--gold-deep); font-variant-numeric: tabular-nums;
  }
  .step-title { font-size: var(--fs-body); font-weight: 700; color: var(--text); line-height: var(--lh-head); }
  .step-body { margin-top: 0.35rem; color: var(--text-dim); font-size: var(--fs-body); line-height: var(--lh-body); max-width: 58ch; }
  @media (hover: hover) {
    .step:hover { background: rgba(191,151,73,0.03); }
    .step:hover .step-no { color: var(--gold); }
  }

  /* --- Specs table --- */
  .dl-specs { padding-block: clamp(1rem, 3vh, 2rem) clamp(2rem, 6vh, 4rem); }
  .specs-table { border: 1px solid var(--brass-soft); background: var(--plate-2); box-shadow: var(--hairline-inset); }
  .specs-row {
    display: grid; grid-template-columns: 1.1fr 1.4fr 1.4fr;
    gap: 1rem; align-items: baseline;
    padding: 0.95rem clamp(0.9rem, 2.5vw, 1.4rem);
    border-bottom: 1px solid var(--brass-soft);
    font-size: var(--fs-small); line-height: var(--lh-body); color: var(--text-dim);
  }
  .specs-row:last-child { border-bottom: 0; }
  .specs-row--head {
    font-family: var(--font-display); font-weight: 700;
    letter-spacing: 0.08em; color: var(--gold-deep);
    background: rgba(191,151,73,0.05);
  }
  .specs-part { color: var(--text); font-weight: 600; }
  .specs-rec { color: var(--text); }

  @media (max-width: 640px) {
    .specs-row { grid-template-columns: 1fr 1fr; }
    .specs-part { grid-column: 1 / -1; padding-bottom: 0.1rem; }
    .specs-row--head span:first-child { display: none; }
    .specs-row--head { grid-template-columns: 1fr 1fr; }
  }
</style>
